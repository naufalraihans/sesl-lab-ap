# ====== Backend Environment ======
# Salin file ini menjadi backend/.env (atau set sebagai env OS)

# Server
APP_PORT=8080
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,https://lab-ap.vercel.app

# Database PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=lab_ap
DB_PARAMS=sslmode=disable TimeZone=Asia/Jakarta

# JWT
JWT_SECRET=ganti-dengan-secret-acak-panjang
JWT_EXPIRE_HOURS=12

# Online registry (server stateful) - TTL entri online dalam detik
ONLINE_TTL_SECONDS=120

# Background auto-submit sweeper - interval dalam detik
SWEEPER_INTERVAL_SECONDS=30

# Supabase Storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=service-role-key
SUPABASE_BUCKET=public-assets

# ====== Frontend (.env di folder frontend) ======
# PUBLIC_API_BASE_URL=http://localhost:8080
# PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=anon-key
